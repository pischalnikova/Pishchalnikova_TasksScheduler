<Window x:Class="TasksScheduler.Views.TaskEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="400"
        Width="500"
        Title="Задача">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Название -->
        <TextBlock Grid.Row="0"
               Grid.Column="0"
               VerticalAlignment="Center"
               Margin="0,5"
               Text="Название:"/>

        <TextBox x:Name="tbName"
             Grid.Row="0"
             Grid.Column="1"
             Width="250"
             Margin="5"/>

        <!-- Описание -->
        <TextBlock Grid.Row="1"
               Grid.Column="0"
               VerticalAlignment="Center"
               Margin="0,5"
               Text="Описание:"/>

        <TextBox x:Name="tbDescription"
             Grid.Row="1"
             Grid.Column="1"
             Width="250"
             Height="60"
             Margin="5"
             TextWrapping="Wrap"
             AcceptsReturn="True"/>

        <!-- Приоритет -->
        <TextBlock Grid.Row="2"
               Grid.Column="0"
               VerticalAlignment="Center"
               Margin="0,5"
               Text="Приоритет:"/>

        <ComboBox x:Name="cbPriority"
              Grid.Row="2"
              Grid.Column="1"
              Width="150"
              Margin="5"/>

        <!-- Срок -->
        <TextBlock Grid.Row="3"
               Grid.Column="0"
               VerticalAlignment="Center"
               Margin="0,5"
               Text="Срок:"/>

        <DatePicker x:Name="dpDeadline"
                Grid.Row="3"
                Grid.Column="1"
                Width="150"
                Margin="5"/>

        <!-- Статус -->
        <TextBlock Grid.Row="4"
               Grid.Column="0"
               VerticalAlignment="Center"
               Margin="0,5"
               Text="Статус:"/>

        <ComboBox x:Name="cbState"
              Grid.Row="4"
              Grid.Column="1"
              Width="150"
              Margin="5"/>

        <!-- Кнопка -->
        <Button Grid.Row="5"
            Grid.ColumnSpan="2"
            Content="OK"
            Width="100"
            Margin="10"
            HorizontalAlignment="Center"
            Click="Ok_Click"/>

    </Grid>

</Window>
